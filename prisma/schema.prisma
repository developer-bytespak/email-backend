generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  phone               String
  city                String
  country             String
  address             String
  hashPassword        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  clientEmails        ClientEmail[]
  clientSms           ClientSms[]
  csvUploads          CsvUpload[]
  emailDrafts         EmailDraft[]
  emailLogs           EmailLog[]
  products            ProductService[]
  senderVerifications SenderVerification[]
  smsDrafts           SmsDraft[]
  smsLogs             SmsLog[]
}

model CsvUpload {
  id                Int             @id @default(autoincrement())
  clientId          Int
  fileName          String
  status            CsvUploadStatus
  totalRecords      Int
  successfulRecords Int
  description       String?
  createdAt         DateTime        @default(now())
  rawData           Json?
  contacts          Contact[]
  client            Client          @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Contact {
  id                Int               @id @default(autoincrement())
  csvUploadId       Int
  businessName      String
  email             String?
  phone             String?
  website           String?
  status            ContactStatus     @default(new)
  valid             Boolean           @default(false)
  validationReason  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  businessNameValid Boolean           @default(false)
  emailValid        Boolean           @default(false)
  scrapeMethod      ScrapeMethod?
  scrapePriority    Int?
  state             String?
  websiteValid      Boolean           @default(false)
  zipCode           String?
  csvUpload         CsvUpload         @relation(fields: [csvUploadId], references: [id])
  emailDrafts       EmailDraft[]
  emailEngagements  EmailEngagement[]
  emailLogs         EmailLog[]
  emailUnsubscribe  EmailUnsubscribe?
  scrapedData       ScrapedData[]
  smsDrafts         SmsDraft[]
  smsLogs           SmsLog[]
  summaries         Summary[]

  @@index([csvUploadId, businessName])
}

model Summary {
  id            Int          @id @default(autoincrement())
  contactId     Int
  summaryText   String
  createdAt     DateTime     @default(now())
  aiModel       String       @default("gemini-2.0-flash-lite")
  keywords      String[]
  opportunities String[]
  scrapedDataId Int?
  strengths     String[]
  updatedAt     DateTime     @default(now()) @updatedAt
  painPoints    String[]
  EmailDraft    EmailDraft[]
  SmsDraft      SmsDraft[]
  contact       Contact      @relation(fields: [contactId], references: [id])
  scrapedData   ScrapedData? @relation(fields: [scrapedDataId], references: [id])
}

model EmailDraft {
  id               Int              @id @default(autoincrement())
  clientEmailId    Int?
  contactId        Int
  clientId         Int
  summaryId        Int
  bodyText         String
  icebreaker       String?
  productsRelevant String?
  status           EmailDraftStatus @default(draft)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt
  subjectLines     String[]
  clientEmail      ClientEmail?     @relation(fields: [clientEmailId], references: [id], onDelete: Restrict)
  Client           Client           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact          Contact          @relation(fields: [contactId], references: [id])
  summary          Summary          @relation(fields: [summaryId], references: [id])
  EmailLog         EmailLog[]
  EmailQueue       EmailQueue?
}

model EmailLog {
  id                 Int                @id @default(autoincrement())
  emailDraftId       Int
  contactId          Int
  clientId           Int?
  status             EmailLogStatus
  providerResponse   Json?
  sentAt             DateTime
  deliveredAt        DateTime?
  messageId          String?            @unique
  sentVia            String             @default("sendgrid")
  spamScore          Int?
  trackingPixelToken String?            @unique
  unsubscribeToken   String?            @unique
  customArgs         Json?
  deferredAt         DateTime?
  processedAt        DateTime?
  retryAttempt       Int?
  smtpId             String?
  templateId         String?
  emailEngagements   EmailEngagement[]
  Client             Client?            @relation(fields: [clientId], references: [id])
  contact            Contact            @relation(fields: [contactId], references: [id])
  emailDraft         EmailDraft         @relation(fields: [emailDraftId], references: [id])
  emailUnsubscribes  EmailUnsubscribe[]
}

model ProductService {
  id           Int                 @id @default(autoincrement())
  clientId     Int
  type         ProductServiceType?
  name         String
  description  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt
  businessName String
  client       Client              @relation(fields: [clientId], references: [id])
}

model ClientEmail {
  id                  Int                      @id @default(autoincrement())
  clientId            Int
  emailAddress        String
  providerSettings    String?
  status              ClientEmailStatus        @default(active)
  mailerTestScore     Decimal?                 @db.Decimal(5, 2)
  totalCounter        Int                      @default(0)
  currentCounter      Int                      @default(0)
  timestamp           DateTime?
  limit               Int                      @default(100)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @default(now()) @updatedAt
  sendgridApiKey      String?
  lastOtpSentAt       DateTime?
  verificationMethod  VerificationMethod       @default(otp)
  verificationStatus  SenderVerificationStatus @default(pending)
  verifiedAt          DateTime?
  client              Client                   @relation(fields: [clientId], references: [id])
  EmailDraft          EmailDraft[]
  senderVerifications SenderVerification?
}

model ClientSms {
  id                  Int                      @id @default(autoincrement())
  clientId            Int
  phoneNumber         String
  providerSettings    String?
  status              ClientSmsStatus          @default(active)
  totalCounter        Int                      @default(0)
  currentCounter      Int                      @default(0)
  timestamp           DateTime?
  limit               Int?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @default(now()) @updatedAt
  lastOtpSentAt       DateTime?
  verificationMethod  VerificationMethod       @default(otp)
  verificationStatus  SenderVerificationStatus @default(pending)
  verifiedAt          DateTime?
  client              Client                   @relation(fields: [clientId], references: [id])
  senderVerifications SenderVerification?
  smsDrafts           SmsDraft[]
  smsLogs             SmsLog[]
}

model SmsDraft {
  id               Int            @id @default(autoincrement())
  contactId        Int
  summaryId        Int?
  messageText      String
  productsRelevant String?
  status           SmsDraftStatus @default(draft)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  clientId         Int
  clientSmsId      Int?
  Client           Client         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientSms        ClientSms?     @relation(fields: [clientSmsId], references: [id])
  contact          Contact        @relation(fields: [contactId], references: [id])
  summary          Summary?       @relation(fields: [summaryId], references: [id])
  SmsLog           SmsLog[]
}

model SmsLog {
  id               Int          @id @default(autoincrement())
  smsDraftId       Int
  contactId        Int
  clientId         Int?
  status           SmsLogStatus
  providerResponse Json?
  sentAt           DateTime
  clientSmsId      Int?
  Client           Client?      @relation(fields: [clientId], references: [id])
  clientSms        ClientSms?   @relation(fields: [clientSmsId], references: [id])
  contact          Contact      @relation(fields: [contactId], references: [id])
  smsDraft         SmsDraft     @relation(fields: [smsDraftId], references: [id])
}

model ScrapedData {
  id              Int          @id @default(autoincrement())
  contactId       Int
  method          ScrapeMethod
  url             String
  searchQuery     String?
  discoveredUrl   String?
  homepageText    String?
  servicesText    String?
  productsText    String?
  contactText     String?
  homepageHtml    String?
  servicesHtml    String?
  productsHtml    String?
  contactHtml     String?
  extractedEmails String[]
  extractedPhones String[]
  pageTitle       String?
  metaDescription String?
  keywords        String[]
  scrapeSuccess   Boolean      @default(false)
  errorMessage    String?
  scrapedAt       DateTime     @default(now())
  solutionsText   String?
  solutionsHtml   String?
  featuresText    String?
  featuresHtml    String?
  blogText        String?
  blogHtml        String?
  contact         Contact      @relation(fields: [contactId], references: [id])
  summaries       Summary[]

  @@index([contactId, scrapedAt])
  @@index([scrapeSuccess])
  @@index([method, scrapedAt])
}

model EmailEngagement {
  id             Int            @id @default(autoincrement())
  emailLogId     Int
  contactId      Int
  engagementType EngagementType
  engagedAt      DateTime       @default(now())
  url            String?
  contact        Contact        @relation(fields: [contactId], references: [id])
  emailLog       EmailLog       @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([emailLogId])
  @@index([contactId])
  @@index([engagementType, engagedAt])
}

model SenderVerification {
  id                 Int                      @id @default(autoincrement())
  senderType         SenderType
  clientEmailId      Int?                     @unique(map: "senderVerification_clientEmailId_key")
  clientSmsId        Int?                     @unique(map: "senderVerification_clientSmsId_key")
  otpHash            String
  otpExpiresAt       DateTime
  attemptCount       Int                      @default(0)
  status             SenderVerificationStatus @default(pending)
  verificationMethod VerificationMethod       @default(otp)
  verifiedAt         DateTime?
  lastOtpSentAt      DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @default(now()) @updatedAt
  clientId           Int
  emailAddress       String?
  phoneNumber        String?
  clientEmail        ClientEmail?             @relation(fields: [clientEmailId], references: [id])
  client             Client                   @relation(fields: [clientId], references: [id])
  clientSms          ClientSms?               @relation(fields: [clientSmsId], references: [id])

  @@index([clientId, emailAddress, status])
  @@index([clientId, phoneNumber, status])
}

model EmailUnsubscribe {
  id                    Int       @id @default(autoincrement())
  contactId             Int       @unique
  unsubscribeEmailLogId Int?
  unsubscribedAt        DateTime  @default(now())
  reason                String?
  contact               Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  emailLog              EmailLog? @relation(fields: [unsubscribeEmailLogId], references: [id])

  @@index([contactId])
}

model EmailQueue {
  id           Int              @id @default(autoincrement())
  emailDraftId Int              @unique
  scheduledAt  DateTime
  status       EmailQueueStatus @default(pending)
  retryCount   Int              @default(0)
  nextRetryAt  DateTime?
  priority     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt
  emailDraft   EmailDraft       @relation(fields: [emailDraftId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt, priority])
}

enum CsvUploadStatus {
  success
  failure
}

enum ContactStatus {
  new
  validated
  ready_to_scrape
  scraping
  scraped
  scrape_failed
  summarized
  drafted
  sent
  opened
  bounced
}

enum ScrapeMethod {
  direct_url
  email_domain
  business_search
}

enum EmailDraftStatus {
  draft
  ready
  sent
}

enum EmailLogStatus {
  success
  failed
  bounced
  pending
  delivered
  blocked
  dropped
  spamreport
  processed
  deferred
}

enum ProductServiceType {
  product
  service
}

enum ClientEmailStatus {
  active
  inactive
}

enum ClientSmsStatus {
  active
  inactive
}

enum SmsDraftStatus {
  draft
  ready
  sent
}

enum SmsLogStatus {
  success
  failed
  delivered
  undelivered
}

enum EngagementType {
  open
  click
}

enum SenderType {
  email
  sms
}

enum SenderVerificationStatus {
  pending
  verified
  expired
  rejected
}

enum VerificationMethod {
  otp
}

enum EmailQueueStatus {
  pending
  sent
  failed
}
